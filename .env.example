# =============================================================================
# IronClad IP — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Core
NODE_ENV=development
PORT=3002
API_KEY=generate-a-secure-api-key-here

# Database (PostgreSQL)
DATABASE_URL=postgresql://ironclad:ironclad@localhost:5432/ironclad_ip

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=ironclad

# Redis
REDIS_URL=redis://localhost:6379

# USPTO API
# Get your key at: https://patentsview.org/apis/api-key-request
USPTO_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# GitHub Integration (for innovation mining)
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_WEBHOOK_SECRET=

# Jira Integration (optional)
JIRA_DOMAIN=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Confluence Integration (optional)
CONFLUENCE_DOMAIN=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# Slack Integration (optional)
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# Email Notifications
EMAIL_FROM=ironclad@yourcompany.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Scanner Configuration
SCANNER_CRON=0 6 * * *
SCANNER_BATCH_SIZE=100
SCANNER_MAX_CONCURRENT=5

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
