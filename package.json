{
  "name": "@thefiredev/ironclad-ip",
  "version": "0.1.0",
  "description": "Autonomous patent offense and defense system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "The Fire Dev LLC <hello@thefiredev.com>",
  "license": "MIT",
  "homepage": "https://thefiredev.com/ironclad-ip",
  "repository": {
    "type": "git",
    "url": "https://github.com/thefiredev/ironclad-ip.git"
  },
  "bugs": {
    "url": "https://github.com/thefiredev/ironclad-ip/issues"
  },
  "keywords": [
    "patent",
    "ip",
    "intellectual-property",
    "uspto",
    "prior-art",
    "innovation",
    "legal-tech"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/reset.ts",
    "scanner:start": "tsx src/scanner/index.ts",
    "scanner:once": "tsx src/scanner/run-once.ts",
    "docker:build": "docker build -t ironclad-ip .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.12.0",
    "bull": "^4.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3",
    "openai": "^4.28.0",
    "pg": "^8.11.3",
    "pino": "^8.18.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.3.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  }
}
